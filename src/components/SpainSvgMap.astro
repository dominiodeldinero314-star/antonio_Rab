<style>
  .province {
    fill: rgba(17, 17, 17, 0.05);
    stroke: rgba(17, 17, 17, 0.16);
    stroke-width: 0.6;
  }
  .ar-label {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 13px;
    fill: #a88b5b;
  }
  .ar-dot {
    animation: ar-dot-pulse 2.5s ease-in-out infinite;
  }
  .ar-r1 {
    animation: ar-r1-pulse 2.5s ease-in-out infinite;
  }
  .ar-r2 {
    animation: ar-r2-pulse 2.5s 0.5s ease-in-out infinite;
  }
  @keyframes ar-dot-pulse {
    0%, 100% { r: 4.5; opacity: 1; }
    50% { r: 6.5; opacity: 0.7; }
  }
  @keyframes ar-r1-pulse {
    0%, 100% { r: 12; opacity: 0.4; }
    50% { r: 17; opacity: 0.1; }
  }
  @keyframes ar-r2-pulse {
    0%, 100% { r: 20; opacity: 0.2; }
    50% { r: 28; opacity: 0.04; }
  }
</style>
