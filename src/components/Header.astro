---
const { transparent = false } = Astro.props;

const baseClasses = 'fixed top-0 inset-x-0 z-50 transition-all duration-300 h-20';
const transparentClasses = 'bg-transparent text-offwhite';
const scrolledClasses = 'bg-cream/95 backdrop-blur-md border-b border-sand text-ink shadow-sm';
---

<header
  class={`${baseClasses} ${transparent ? transparentClasses : scrolledClasses}`}
  data-transparent={transparent ? 'true' : 'false'}
  id="site-header"
>
  <div class="flex justify-between items-center h-full px-6 md:px-16 max-w-[1440px] mx-auto">
    <a class="flex items-baseline gap-2" href="/">
      <span class="font-display font-bold text-2xl md:text-3xl">AR</span>
      <span class="font-display text-xl md:text-2xl">Antonio Rabadán</span>
    </a>
    <nav class="hidden md:flex items-center gap-10">
      <a class="text-sm font-sans font-semibold uppercase tracking-wide opacity-90 hover:opacity-100 hover:text-gold transition-all duration-300" href="/">Inicio</a>
      <a class="text-sm font-sans font-semibold uppercase tracking-wide opacity-90 hover:opacity-100 hover:text-gold transition-all duration-300" href="/proyectos">Proyectos</a>
      <a class="text-sm font-sans font-semibold uppercase tracking-wide opacity-90 hover:opacity-100 hover:text-gold transition-all duration-300" href="/servicios">Servicios</a>
      <a class="text-sm font-sans font-semibold uppercase tracking-wide opacity-90 hover:opacity-100 hover:text-gold transition-all duration-300" href="/estudio">Estudio</a>
      <a class="text-sm font-sans font-semibold uppercase tracking-wide opacity-90 hover:opacity-100 hover:text-gold transition-all duration-300" href="/contacto">Contacto</a>
    </nav>
    <button aria-controls="mobile-menu" aria-expanded="false" aria-label="Abrir menú" class="md:hidden" id="menu-toggle">
      <span class="material-symbols-outlined text-3xl" id="menu-icon">menu</span>
    </button>
  </div>
</header>

<div class="hidden md:!hidden fixed top-24 inset-x-6 max-w-xs mx-auto z-40 bg-offwhite rounded-3xl shadow-2xl p-3" id="mobile-menu">
  <nav class="flex flex-col">
    <a class="font-display text-lg text-ink border-b border-sand py-3.5 px-3 hover:text-gold hover:pl-5 transition-all duration-300" href="/">Inicio</a>
    <a class="font-display text-lg text-ink border-b border-sand py-3.5 px-3 hover:text-gold hover:pl-5 transition-all duration-300" href="/proyectos">Proyectos</a>
    <a class="font-display text-lg text-ink border-b border-sand py-3.5 px-3 hover:text-gold hover:pl-5 transition-all duration-300" href="/servicios">Servicios</a>
    <a class="font-display text-lg text-ink border-b border-sand py-3.5 px-3 hover:text-gold hover:pl-5 transition-all duration-300" href="/estudio">Estudio</a>
    <a class="font-display text-lg text-ink py-3.5 px-3 hover:text-gold hover:pl-5 transition-all duration-300" href="/contacto">Contacto</a>
  </nav>
</div>

<script>
  const header = document.getElementById('site-header');
  const transparentClasses = ['bg-transparent', 'text-offwhite'];
  const scrolledClasses = ['bg-cream/95', 'backdrop-blur-md', 'border-b', 'border-sand', 'text-ink', 'shadow-sm'];
  let isTransparent = false;

  function applyScrolled(scrolled) {
    if (!header) return;
    if (scrolled) {
      header.classList.remove(...transparentClasses);
      header.classList.add(...scrolledClasses);
    } else if (isTransparent) {
      header.classList.remove(...scrolledClasses);
      header.classList.add(...transparentClasses);
    }
  }

  const onScroll = () => applyScrolled(window.scrollY > 40);

  if (header) {
    isTransparent = header.dataset.transparent === 'true';
    window.addEventListener('scroll', onScroll);
    onScroll();
  }

  const menuToggle = document.getElementById('menu-toggle');
  const menuIcon = document.getElementById('menu-icon');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuToggle && menuIcon && mobileMenu) {
    function setMobileMenuOpen(open) {
      mobileMenu.classList.toggle('hidden', !open);
      menuToggle.setAttribute('aria-expanded', String(open));
      menuIcon.textContent = open ? 'close' : 'menu';
      document.body.classList.toggle('overflow-hidden', open);
      // Mientras el menú está abierto, el header se fuerza a su estado "sólido"
      // para que el logo y el icono de cerrar sigan siendo visibles.
      applyScrolled(open || window.scrollY > 40);
    }

    menuToggle.addEventListener('click', () => {
      setMobileMenuOpen(mobileMenu.classList.contains('hidden'));
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setMobileMenuOpen(false));
    });
  }
</script>
