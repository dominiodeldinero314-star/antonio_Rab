---
import Layout from '../../layouts/Layout.astro';
import { services } from '../../data/services.js';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout description={service.excerpt} title={service.name}>
  <section class="pt-40 pb-20 px-6 md:px-16 max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
    <div class="md:col-span-6 fade-in-up">
      <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gold mb-4 block">Servicios</span>
      <h1 class="font-display text-4xl md:text-6xl leading-tight mb-6">{service.name}</h1>
      <p class="font-serif italic text-xl text-graphite leading-relaxed">{service.excerpt}</p>
    </div>
    <div class="md:col-span-6 fade-in-up" style="transition-delay: 150ms;">
      <div class="rounded-3xl overflow-hidden aspect-[4/3]">
        <div class="w-full h-full bg-cover bg-center" style={`background-image: url('${service.image}')`}></div>
      </div>
    </div>
  </section>

  <section class="bg-sand py-24 md:py-32 px-6 md:px-16 max-w-[1440px] mx-auto rounded-3xl">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <div class="md:col-span-7 fade-in-up">
        <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gold mb-4 block">En qué consiste</span>
        <p class="text-graphite text-base md:text-lg leading-relaxed">{service.explanation}</p>
      </div>
      <div class="md:col-span-5 fade-in-up" style="transition-delay: 150ms;">
        <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gold mb-4 block">Beneficios</span>
        <ul class="space-y-4">
          {service.benefits.map((b) => (
            <li class="flex gap-3 text-ink font-sans">
              <span class="material-symbols-outlined text-gold mt-0.5">check_circle</span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 px-6 md:px-16 max-w-[1440px] mx-auto text-center">
    <div class="fade-in-up">
      <h2 class="font-display text-3xl md:text-5xl leading-tight mb-8 max-w-2xl mx-auto">¿Quieres este servicio para tu proyecto?</h2>
      <a class="rounded-full bg-gold text-ink font-sans font-semibold px-10 py-4 hover:bg-ink hover:text-offwhite transition-colors inline-block" href="/contacto">
        Solicitar proyecto
      </a>
    </div>
  </section>
</Layout>
