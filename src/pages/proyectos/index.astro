---
import Layout from '../../layouts/Layout.astro';
import { projects, categories } from '../../data/projects.js';
---

<Layout description="Proyectos de arquitectura residencial, reformas, interiorismo y espacios comerciales." title="Proyectos">
  <section class="pt-40 pb-16 px-6 md:px-16 max-w-[1440px] mx-auto">
    <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gold mb-4 block fade-in-up">Portfolio</span>
    <h1 class="font-display text-4xl md:text-6xl leading-tight mb-6 max-w-2xl fade-in-up">Proyectos</h1>
    <p class="text-graphite text-base md:text-lg max-w-xl leading-relaxed fade-in-up" style="transition-delay: 100ms;">
      Una selección de viviendas, reformas, proyectos de interiorismo y espacios comerciales desarrollados por el estudio.
    </p>
  </section>

  <section class="px-6 md:px-16 max-w-[1440px] mx-auto mb-10">
    <div class="flex flex-wrap gap-3" id="filters">
      <button class="filter-btn rounded-full px-6 py-2 text-sm font-sans font-semibold uppercase tracking-wide bg-ink text-offwhite" data-filter="Todos">Todos</button>
      {categories.map((cat) => (
        <button class="filter-btn rounded-full px-6 py-2 text-sm font-sans font-semibold uppercase tracking-wide bg-sand text-ink hover:bg-gold hover:text-ink transition-colors" data-filter={cat}>
          {cat}
        </button>
      ))}
    </div>
  </section>

  <section class="px-6 md:px-16 max-w-[1440px] mx-auto pb-24 md:pb-32">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" id="projects-grid">
      {projects.map((project) => (
        <a class="project-item group relative aspect-[4/3] rounded-3xl overflow-hidden shadow-sm block" data-category={project.category} href={`/proyectos/${project.slug}`}>
          <div class="w-full h-full bg-cover bg-center transition-transform duration-1000 group-hover:scale-105" style={`background-image: url('${project.image}')`}></div>
          <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/10 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-7 text-offwhite">
            <p class="text-xs font-sans font-semibold uppercase tracking-wide text-gold mb-2">{project.category} · {project.location}</p>
            <h3 class="font-display text-xl">{project.name}</h3>
          </div>
        </a>
      ))}
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.project-item');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        buttons.forEach((b) => b.classList.remove('bg-ink', 'text-offwhite'));
        buttons.forEach((b) => b.classList.add('bg-sand', 'text-ink'));
        btn.classList.remove('bg-sand');
        btn.classList.add('bg-ink', 'text-offwhite');

        items.forEach((item) => {
          const matches = filter === 'Todos' || item.getAttribute('data-category') === filter;
          item.classList.toggle('hidden', !matches);
        });
      });
    });
  </script>
</Layout>
