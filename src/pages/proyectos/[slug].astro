---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects.js';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const paragraphs = project.story.split('\n\n');
---

<Layout description={project.excerpt} title={project.name} transparentHeader={true}>
  <!-- HERO A PANTALLA COMPLETA -->
  <section class="relative h-screen w-full overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="w-full h-full bg-cover bg-center" style={`background-image: url('${project.image}')`}></div>
      <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/20 to-ink/10"></div>
    </div>
    <div class="relative z-10 flex flex-col justify-end h-full px-6 md:px-16 max-w-[1440px] mx-auto pb-20">
      <p class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gold mb-4">{project.category} · {project.location}</p>
      <h1 class="font-display text-4xl md:text-6xl text-offwhite max-w-2xl">{project.name}</h1>
    </div>
  </section>

  <!-- HISTORIA DEL PROYECTO -->
  <section class="py-28 md:py-40 px-6 md:px-16 max-w-[1440px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <div class="md:col-span-7 fade-in-up">
        <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.25em] text-gold mb-5 block">El proyecto</span>
        {paragraphs.map((p) => (
          <p class="text-graphite text-base md:text-lg leading-relaxed mb-6">{p}</p>
        ))}
      </div>
      <div class="md:col-span-5 fade-in-up" style="transition-delay: 150ms;">
        <div class="rounded-3xl bg-sand p-8 space-y-6">
          <div>
            <span class="text-xs font-sans font-semibold uppercase tracking-wide text-gold block mb-1">Ubicación</span>
            <span class="text-ink font-sans">{project.location}</span>
          </div>
          <div>
            <span class="text-xs font-sans font-semibold uppercase tracking-wide text-gold block mb-1">Categoría</span>
            <span class="text-ink font-sans">{project.category}</span>
          </div>
          <div>
            <span class="text-xs font-sans font-semibold uppercase tracking-wide text-gold block mb-2">Servicios realizados</span>
            <ul class="space-y-2">
              {project.services.map((s) => (
                <li class="text-ink font-sans flex gap-2">
                  <span class="material-symbols-outlined text-base text-gold mt-0.5">check</span>
                  <span>{s}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GALERÍA -->
  <section class="px-6 md:px-16 max-w-[1440px] mx-auto pb-28 md:pb-40">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {project.gallery.map((img, i) => (
        <div class={`overflow-hidden aspect-[4/5] fade-in-up ${i === 0 ? 'md:col-span-2 md:row-span-2 aspect-auto md:aspect-[16/11]' : ''}`} style={`transition-delay: ${i * 100}ms;`}>
          <div class="w-full h-full bg-cover bg-center transition-transform duration-[1400ms] ease-out hover:scale-105" style={`background-image: url('${img}')`}></div>
        </div>
      ))}
    </div>
  </section>

  <!-- FOTOGRAFÍA A PANTALLA COMPLETA -->
  <section class="relative h-[70vh] w-full overflow-hidden">
    <div class="w-full h-full bg-cover bg-center ken-burns" style={`background-image: url('${project.gallery[1] ?? project.image}')`}></div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-28 md:py-44 px-6 md:px-16 max-w-[1440px] mx-auto text-center">
    <div class="fade-in-up">
      <h2 class="font-display text-4xl md:text-6xl leading-tight mb-10 max-w-2xl mx-auto">¿Te gustaría un proyecto como este?</h2>
      <a class="rounded-full bg-gold text-ink font-sans font-semibold px-10 py-4 hover:bg-ink hover:text-offwhite transition-all duration-300 inline-block" href="/contacto">
        Solicitar proyecto
      </a>
    </div>
  </section>
</Layout>
