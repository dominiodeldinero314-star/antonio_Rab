---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getFeaturedProjects } from '../data/projects.js';
import { services } from '../data/services.js';
import { testimonials } from '../data/testimonials.js';
import SpainSvgMap from '../components/SpainSvgMap.astro';
import { IMG_VILLA } from '../data/images.js';

const featuredProjects = getFeaturedProjects();
---

<Layout
  description="Antonio Rabadán es arquitecto en Murcia, Madrid y Barcelona. Arquitectura residencial, viviendas de lujo, reformas integrales e interiorismo en toda España."
  title="Arquitecto en Murcia, Madrid y Barcelona"
  transparentHeader={true}
>
  <script is:inline>
    if ('scrollRestoration' in history) {
      history.scrollRestoration = 'manual';
    }
    window.scrollTo(0, 0);
  </script>
  <!-- HERO -->
  <section class="relative h-screen w-full overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="w-full h-full bg-cover bg-center ken-burns" style={`background-image: url('${IMG_VILLA}')`}></div>
      <div class="absolute inset-0 bg-gradient-to-t from-ink/75 via-ink/20 to-ink/10"></div>
    </div>
    <div class="relative z-10 flex flex-col justify-center items-center text-center md:items-start md:text-left h-full px-6 md:px-16 max-w-[1440px] mx-auto">
      <h1 class="font-display text-4xl sm:text-6xl md:text-7xl lg:text-8xl leading-[1.1] sm:leading-[1.05] tracking-tight text-offwhite max-w-3xl mb-12 enter-up">
        Arquitectura que transforma espacios.
      </h1>
      <div class="flex flex-col items-center w-full max-w-xs mx-auto sm:max-w-none sm:w-auto sm:flex-row gap-4 enter-up" style="animation-delay: 200ms;">
        <a class="w-full sm:w-auto rounded-full bg-gold text-ink font-sans font-semibold px-10 py-4 hover:bg-offwhite transition-all duration-300 text-center" href="/contacto">
          Solicitar proyecto
        </a>
        <a class="w-full sm:w-auto rounded-full border border-offwhite/50 text-offwhite font-sans font-semibold px-10 py-4 hover:bg-offwhite/10 hover:border-offwhite transition-all duration-300 text-center" href="/proyectos">
          Ver proyectos
        </a>
      </div>
    </div>
    <div class="absolute bottom-10 inset-x-0 hidden md:flex flex-col items-center gap-3 text-offwhite/60 enter-up" style="animation-delay: 500ms;">
      <span class="text-[10px] font-sans uppercase tracking-[0.3em]">Descubre</span>
      <span class="w-px h-9 bg-offwhite/40"></span>
    </div>
  </section>

  <!-- PROYECTOS DESTACADOS -->
  <section class="py-28 md:py-44" id="proyectos">
    <div class="px-6 md:px-16 max-w-[1440px] mx-auto mb-16 md:mb-24 flex flex-col sm:flex-row sm:justify-between sm:items-end gap-6 fade-in-up">
      <div>
        <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.25em] text-gold mb-5 block">Selección</span>
        <h2 class="font-display text-4xl md:text-6xl leading-tight">Proyectos destacados</h2>
      </div>
      <a class="text-sm font-sans font-semibold uppercase tracking-wide text-ink border-b-2 border-gold pb-1 hover:text-gold transition-all duration-300 w-fit" href="/proyectos">
        Ver todos los proyectos
      </a>
    </div>
    <div class="px-6 md:px-16 max-w-[1100px] mx-auto grid grid-cols-1 gap-20 md:gap-32">
      {featuredProjects.map((project, i) => <ProjectCard project={project} delay={i * 100} />)}
    </div>
  </section>

  <!-- ESTUDIO -->
  <section class="bg-sand py-28 md:py-44">
    <div class="px-6 md:px-16 max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-12 gap-14 md:gap-16 items-center">
      <div class="md:col-span-6 fade-in-up">
        <div class="aspect-[4/5] overflow-hidden">
          <img alt="Antonio Rabadán, arquitecto fundador del estudio" class="w-full h-full object-cover" src="/images/FotoAntonioRabadan.jpeg" />
        </div>
      </div>
      <div class="md:col-span-6 fade-in-up" style="transition-delay: 150ms;">
        <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.25em] text-gold mb-5 block">El estudio</span>
        <h2 class="font-display text-4xl md:text-6xl leading-tight mb-10">Antonio Rabadán</h2>
        <p class="text-graphite text-base md:text-lg leading-relaxed mb-12">
          Arquitecto en Murcia, Madrid y Barcelona. Quince años defendiendo una arquitectura serena, atenta a la luz
          y a quien habita cada espacio.
        </p>
        <a class="rounded-full border border-ink text-ink font-sans font-semibold px-9 py-4 hover:bg-ink hover:text-offwhite transition-all duration-300 inline-block" href="/estudio">
          Conocer el estudio
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="py-28 md:py-44 px-6 md:px-16 max-w-[1440px] mx-auto">
    <div class="text-center mb-20 md:mb-24 fade-in-up">
      <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.25em] text-gold mb-5 block">Servicios</span>
      <h2 class="font-display text-4xl md:text-6xl leading-tight">Arquitectura, interiorismo y reformas integrales</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-x-10 md:gap-y-16 mb-20">
      {services.map((service, i) => <ServiceCard service={service} delay={(i % 3) * 100} />)}
    </div>
    <div class="text-center fade-in-up">
      <a class="rounded-full bg-ink text-offwhite font-sans font-semibold px-9 py-4 hover:bg-gold hover:text-ink transition-all duration-300 inline-block" href="/servicios">
        Ver servicios
      </a>
    </div>
  </section>

  <!-- PROCESO -->
  <section class="bg-ink text-offwhite py-28 md:py-44">
    <div class="px-6 md:px-16 max-w-[1440px] mx-auto">
      <div class="mb-20 md:mb-24 fade-in-up">
        <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.25em] text-gold mb-5 block">El proceso</span>
        <h2 class="font-display text-4xl md:text-6xl leading-tight">De la idea a la realidad</h2>
      </div>
      <div class="relative">
        <div class="hidden md:block absolute left-6 top-2 bottom-2 w-px bg-offwhite/15"></div>
        {[
          { n: '01', title: 'Primera reunión', text: 'Escuchamos tus necesidades, sueños y el propósito del espacio para trazar el punto de partida.' },
          { n: '02', title: 'Concepto y diseño', text: 'Desarrollo de las primeras líneas, volúmenes y la esencia arquitectónica del proyecto.' },
          { n: '03', title: 'Proyecto técnico', text: 'Precisión absoluta en planos, licencias y especificaciones para garantizar la viabilidad total.' },
          { n: '04', title: 'Ejecución', text: 'Dirección de obra exhaustiva. Cuidamos que cada milímetro construido sea fiel al diseño.' },
          { n: '05', title: 'Entrega', text: 'El momento final donde el espacio cobra vida y el cliente comienza su nueva experiencia.' },
        ].map((step) => (
          <div class="relative flex items-start gap-6 md:gap-10 py-10 md:py-14 border-b border-offwhite/10 last:border-b-0 fade-in-up">
            <span class="relative z-10 flex items-center justify-center w-12 h-12 shrink-0 rounded-full bg-ink border border-gold text-gold font-display">{step.n}</span>
            <div class="pt-2">
              <h4 class="font-display text-xl md:text-2xl mb-3">{step.title}</h4>
              <p class="text-offwhite/70 leading-relaxed max-w-xl">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="py-28 md:py-44 px-6 md:px-16 max-w-[1440px] mx-auto">
    <div class="text-center mb-20 md:mb-24 fade-in-up">
      <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.25em] text-gold mb-5 block">Testimonios</span>
      <h2 class="font-display text-4xl md:text-6xl leading-tight">La confianza de nuestros clientes</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t, i) => (
        <div class="rounded-3xl bg-sand p-10 md:p-12 fade-in-up" style={`transition-delay: ${i * 150}ms;`}>
          <p class="font-sans text-base leading-relaxed text-ink mb-8">&ldquo;{t.quote}&rdquo;</p>
          <div class="flex items-center gap-4">
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-gold/20 text-gold font-display">{t.initials}</span>
            <div>
              <p class="font-sans font-semibold text-ink">{t.name}</p>
              <p class="text-sm text-graphite">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- PRESENCIA -->
  <section class="bg-sand py-28 md:py-44 overflow-hidden">
    <div class="px-6 md:px-16 max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-14 md:gap-16 items-center">
      <div class="fade-in-up">
        <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.25em] text-gold mb-5 block">Ubicación</span>
        <h2 class="font-display text-4xl md:text-6xl leading-tight mb-10">Arquitecto en Murcia, Madrid y Barcelona</h2>
        <p class="text-graphite text-base md:text-lg leading-relaxed mb-10">
          Con oficinas en estas tres ciudades, desarrollamos proyectos residenciales y comerciales en toda España,
          adaptándonos siempre al clima, la luz y la cultura de cada lugar.
        </p>
        <div class="flex justify-center gap-8 w-full">
          <span class="text-sm font-sans font-semibold uppercase tracking-wide text-gold">Murcia</span>
          <span class="text-sm font-sans font-semibold uppercase tracking-wide text-gold">Madrid</span>
          <span class="text-sm font-sans font-semibold uppercase tracking-wide text-gold">Barcelona</span>
        </div>
      </div>
      <div class="relative aspect-[480/380] md:aspect-auto md:h-[500px] overflow-hidden fade-in-up" style="transition-delay: 200ms;">
        <SpainSvgMap />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 md:py-52 px-6 md:px-16 max-w-[1440px] mx-auto text-center">
    <div class="fade-in-up">
      <h2 class="font-display text-4xl md:text-6xl leading-tight mb-12 max-w-2xl mx-auto">¿Hablamos sobre tu próximo proyecto?</h2>
      <a class="rounded-full bg-gold text-ink font-sans font-semibold px-10 py-4 hover:bg-ink hover:text-offwhite transition-all duration-300 inline-block" href="/contacto">
        Solicitar proyecto
      </a>
    </div>
  </section>

</Layout>
