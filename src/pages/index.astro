---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getFeaturedProjects } from '../data/projects.js';
import { services } from '../data/services.js';
import { testimonials } from '../data/testimonials.js';
import SpainMap from '../components/SpainMap.astro';
import { IMG_VILLA } from '../data/images.js';

const featuredProjects = getFeaturedProjects();
---

<Layout title="Inicio" transparentHeader={true}>
  <!-- HERO -->
  <section class="relative h-screen w-full overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="w-full h-full bg-cover bg-center ken-burns" style={`background-image: url('${IMG_VILLA}')`}></div>
      <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/30 to-ink/10"></div>
    </div>
    <div class="relative z-10 flex flex-col justify-center items-center text-center md:items-start md:text-left h-full px-6 md:px-16 max-w-[1440px] mx-auto">
      <div class="w-full text-center mb-8">
        <span class="block text-[10px] md:text-xs font-sans font-semibold uppercase tracking-[0.3em] text-offwhite/70">Murcia · Madrid · Barcelona</span>
      </div>
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-tight text-offwhite max-w-3xl mb-10 text-left self-start">
        Arquitectura que transforma espacios en experiencias únicas.
      </h1>
      <div class="flex flex-col items-center w-full max-w-xs mx-auto sm:max-w-none sm:w-auto sm:flex-row gap-4">
        <a class="w-full sm:w-auto rounded-full bg-gold text-ink font-sans font-semibold px-9 py-4 hover:bg-offwhite transition-colors text-center" href="/proyectos">
          Ver proyectos
        </a>
        <a class="w-full sm:w-auto rounded-full border border-offwhite/50 text-offwhite font-sans font-semibold px-9 py-4 hover:bg-offwhite/10 transition-colors text-center" href="/contacto">
          Solicitar proyecto
        </a>
      </div>
    </div>
  </section>

  <!-- PROYECTOS DESTACADOS -->
  <section class="py-24 md:py-32" id="proyectos">
    <div class="px-6 md:px-16 max-w-[1440px] mx-auto mb-14 flex flex-col sm:flex-row sm:justify-between sm:items-end gap-4 fade-in-up">
      <div>
        <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gold mb-4 block">Selección</span>
        <h2 class="font-display text-3xl md:text-5xl">Proyectos destacados</h2>
      </div>
      <a class="text-sm font-sans font-semibold uppercase tracking-wide text-ink border-b-2 border-gold pb-1 hover:text-gold transition-colors w-fit" href="/proyectos">
        Ver todos los proyectos
      </a>
    </div>
    <div class="px-6 md:px-16 max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
      {featuredProjects.map((project, i) => <ProjectCard project={project} delay={i * 150} />)}
    </div>
  </section>

  <!-- ESTUDIO -->
  <section class="bg-sand py-24 md:py-32">
    <div class="px-6 md:px-16 max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-5 fade-in-up">
        <div class="aspect-[4/5] rounded-3xl bg-ink flex items-center justify-center">
          <span class="font-display text-6xl text-offwhite/40">AR</span>
        </div>
      </div>
      <div class="md:col-span-7 fade-in-up" style="transition-delay: 150ms;">
        <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gold mb-4 block">El estudio</span>
        <h2 class="font-display text-3xl md:text-5xl leading-tight mb-8">Antonio Rabadán</h2>
        <p class="text-graphite text-base md:text-lg leading-relaxed mb-10">
          Antonio Rabadán dirige un estudio de arquitectura e interiorismo con oficinas en Murcia, Madrid y Barcelona, y
          proyectos en toda España. Durante más de quince años hemos defendido una arquitectura serena, atenta a la luz,
          los materiales y el modo de vida de cada cliente. Creemos que el verdadero lujo está en la coherencia: en que
          cada decisión, por pequeña que sea, responda a una idea clara del espacio.
        </p>
        <a class="rounded-full border border-ink text-ink font-sans font-semibold px-9 py-4 hover:bg-ink hover:text-offwhite transition-colors inline-block" href="/estudio">
          Conocer el estudio
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="py-24 md:py-32 px-6 md:px-16 max-w-[1440px] mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gold mb-4 block">Servicios</span>
      <h2 class="font-display text-3xl md:text-5xl">Soluciones integrales de diseño</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-14">
      {services.map((service, i) => <ServiceCard service={service} delay={i * 100} />)}
    </div>
    <div class="text-center fade-in-up">
      <a class="rounded-full bg-ink text-offwhite font-sans font-semibold px-9 py-4 hover:bg-gold hover:text-ink transition-colors inline-block" href="/servicios">
        Ver servicios
      </a>
    </div>
  </section>

  <!-- PROCESO -->
  <section class="bg-ink text-offwhite py-24 md:py-32">
    <div class="px-6 md:px-16 max-w-[1440px] mx-auto">
      <div class="mb-16 fade-in-up">
        <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gold mb-4 block">El proceso</span>
        <h2 class="font-display text-3xl md:text-5xl">De la idea a la realidad</h2>
      </div>
      <div class="relative">
        <div class="hidden md:block absolute left-6 top-2 bottom-2 w-px bg-offwhite/15"></div>
        {[
          { n: '01', title: 'Primera reunión', text: 'Escuchamos tus necesidades, sueños y el propósito del espacio para trazar el punto de partida.' },
          { n: '02', title: 'Concepto y diseño', text: 'Desarrollo de las primeras líneas, volúmenes y la esencia arquitectónica del proyecto.' },
          { n: '03', title: 'Proyecto técnico', text: 'Precisión absoluta en planos, licencias y especificaciones para garantizar la viabilidad total.' },
          { n: '04', title: 'Ejecución', text: 'Dirección de obra exhaustiva. Cuidamos que cada milímetro construido sea fiel al diseño.' },
          { n: '05', title: 'Entrega', text: 'El momento final donde el espacio cobra vida y el cliente comienza su nueva experiencia.' },
        ].map((step) => (
          <div class="relative flex items-start gap-6 md:gap-10 py-8 md:py-12 border-b border-offwhite/10 last:border-b-0 fade-in-up">
            <span class="relative z-10 flex items-center justify-center w-12 h-12 shrink-0 rounded-full bg-ink border border-gold text-gold font-display">{step.n}</span>
            <div class="pt-2">
              <h4 class="font-display text-xl md:text-2xl mb-3">{step.title}</h4>
              <p class="text-offwhite/70 leading-relaxed max-w-xl">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="py-24 md:py-32 px-6 md:px-16 max-w-[1440px] mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gold mb-4 block">Testimonios</span>
      <h2 class="font-display text-3xl md:text-5xl">La confianza de nuestros clientes</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t, i) => (
        <div class="rounded-3xl bg-sand p-10 fade-in-up" style={`transition-delay: ${i * 150}ms;`}>
          <p class="font-serif italic text-xl leading-relaxed text-ink mb-8">&ldquo;{t.quote}&rdquo;</p>
          <div class="flex items-center gap-4">
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-gold/20 text-gold font-display">{t.initials}</span>
            <div>
              <p class="font-sans font-semibold text-ink">{t.name}</p>
              <p class="text-sm text-graphite">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- PRESENCIA -->
  <section class="bg-sand py-24 md:py-32 overflow-hidden">
    <div class="px-6 md:px-16 max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="fade-in-up">
        <span class="text-xs md:text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gold mb-4 block">Ubicación</span>
        <h2 class="font-display text-3xl md:text-5xl leading-tight mb-8">Presencia en toda España</h2>
        <p class="text-graphite text-base md:text-lg leading-relaxed mb-8">
          Con oficinas en Murcia, Madrid y Barcelona, desarrollamos proyectos residenciales y comerciales en toda España,
          adaptándonos siempre al clima, la luz y la cultura de cada lugar.
        </p>
        <div class="flex gap-8">
          <div class="flex flex-col">
            <span class="text-sm font-sans font-semibold uppercase tracking-wide text-gold">Murcia</span>
            <span class="text-graphite">Sede central</span>
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-sans font-semibold uppercase tracking-wide text-gold">Madrid</span>
            <span class="text-graphite">Oficina</span>
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-sans font-semibold uppercase tracking-wide text-gold">Barcelona</span>
            <span class="text-graphite">Oficina</span>
          </div>
        </div>
      </div>
      <div class="relative h-[420px] md:h-[500px] rounded-3xl overflow-hidden fade-in-up shadow-sm" style="transition-delay: 200ms;">
        <SpainMap id="spain-map-home" />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32 px-6 md:px-16 max-w-[1440px] mx-auto text-center">
    <div class="fade-in-up">
      <h2 class="font-display text-3xl md:text-5xl leading-tight mb-8 max-w-2xl mx-auto">¿Hablamos sobre tu próximo proyecto?</h2>
      <a class="rounded-full bg-gold text-ink font-sans font-semibold px-10 py-4 hover:bg-ink hover:text-offwhite transition-colors inline-block" href="/contacto">
        Solicitar proyecto
      </a>
    </div>
  </section>
</Layout>
